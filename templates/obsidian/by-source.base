filters:
  and:
    - type != null
properties:
  file.name:
    displayName: Note
  type:
    displayName: Type
  date:
    displayName: Date
  project:
    displayName: Project
views:
  - type: table
    name: By source
    groupBy:
      property: source
      direction: ASC
    order:
      - file.name
      - type
      - date
      - project
